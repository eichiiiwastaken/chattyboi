# ==================== PostgreSQL ====================
POSTGRES_URL=postgres://chattyboi:change-me@postgres:5432/chattyboi
POSTGRES_USER=chattyboi
POSTGRES_PASSWORD=change-me
POSTGRES_DB=chattyboi

# ==================== Redis ====================
REDIS_URL=redis://redis:6379

# ==================== Rate Limits ====================
# Optional. Leave unset for no hourly chat limits.
# CHAT_MAX_MESSAGES_PER_HOUR=100
# IP_MAX_MESSAGES_PER_HOUR=100

# ==================== App Image ====================
# Required for production deployments. Use the image published by GitHub Actions.
CHATTYBOI_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/chattyboi:latest

# ==================== NextAuth ====================
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-random-secret
NEXTAUTH_URL=http://localhost:3232

# Allowed users (JSON array). No users are configured unless this is set.
# Prefer pre-hashed passwords. Plaintext passwords are hashed at boot only for local setup.
# Keep real users in .env or your host's secret store — never commit them to git.
# ALLOWED_USERS='[{"username":"local-user","name":"Local User","passwordHash":"$2a$10$replace-with-bcrypt-hash"}]'

# ==================== AI Gateway ====================
# Required for non-Vercel deployments
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=replace-with-ai-gateway-key

# ==================== Vercel Blob ====================
# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=replace-with-blob-token

# ==================== AI Providers ====================
OPENAI_API_KEY=replace-with-openai-api-key
OPENCODE_API_KEY=replace-with-opencode-api-key
OPENROUTER_API_KEY=replace-with-openrouter-api-key
# Optional. Use "exa" or "tavily"; unset auto-selects Exa when EXA_API_KEY is present, then Tavily.
# WEB_SEARCH_PROVIDER=exa
EXA_API_KEY=replace-with-exa-api-key
TAVILY_API_KEY=replace-with-tavily-api-key
GROQ_API_KEY=replace-with-groq-api-key
